menu "Meatreader WiFi"

    config WIFI_SSID
        string "WiFi SSID"
        default ""
        help
            SSID (network name) for the development WiFi AP.
            Can be overridden at runtime via PATCH /config/staged + apply + commit.

    config WIFI_PASSWORD
        string "WiFi Password"
        default ""
        help
            WiFi password. Leave empty for open networks.

endmenu
