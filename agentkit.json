{
  "todo": {
    "path": "TODO.md",
    "task_id_strategy": "phase-line",
    "status_markers": {
      "open": "- [ ]",
      "done": "- [x]"
    }
  },
  "index": {
    "exclude_paths": [
      ".claude/worktrees",
      ".claude/debug",
      ".claude/file-history",
      "firmware/build",
      "firmware/.direnv",
      "firmware/managed_components",
      "firmware/build",
      "firmware/.cache",
      "firmware/.pytest_cache",
      "thermometer-ui/dist",
      "thermometer-ui/.svelte-kit",
      "thermometer-ui/node_modules"
    ],
    "max_file_bytes": 180000
  },
  "context": {
    "default_token_budget": 2800,
    "max_files_per_pack": 12,
    "max_tests_per_pack": 5,
    "prefer_symbol_blocks": true,
    "max_snippets_total": 20,
    "max_snippets_per_file": 3
  },
  "extract": {
    "enabled": true,
    "max_file_bytes": 180000,
    "languages": {
      "c": "regex-c",
      "h": "regex-c",
      "cpp": "regex-c",
      "cc": "regex-c",
      "ts": "regex-ts",
      "js": "regex-ts",
      "py": "regex-py",
      "svelte": "regex-ts"
    },
    "adapters": [
      {
        "type": "builtin",
        "name": "esp-idf-http-routes",
        "include_ext": [
          "c",
          "h"
        ],
        "include_paths": [
          "firmware/components/http_server/"
        ]
      },
      {
        "type": "builtin",
        "name": "svelte-live-api",
        "include_ext": [
          "ts",
          "svelte"
        ],
        "include_paths": [
          "thermometer-ui/src/lib/api/",
          "thermometer-ui/src/lib/stores/"
        ]
      },
      {
        "type": "builtin",
        "name": "typescript-stores",
        "include_ext": [
          "ts"
        ],
        "include_paths": [
          "thermometer-ui/src/lib/stores/"
        ]
      },
      {
        "type": "python",
        "name": "meatreader-custom",
        "file": "agentkit-adapters/meatreader_adapter.py",
        "function": "extract",
        "include_ext": [
          "c",
          "h",
          "ts",
          "svelte"
        ],
        "include_paths": [
          "firmware/components/http_server/",
          "thermometer-ui/src/"
        ]
      }
    ]
  },
  "test_hints": {
    "firmware": "cd firmware/tests && cmake -B build && cmake --build build && ctest --test-dir build",
    "ui": "cd thermometer-ui && npm run test"
  },
  "governance": {
    "mode": "allowlist-soft-warn",
    "worker_allowlist_profile": "lean-code-edit-v1",
    "worker_allowed_tools": [
      "Read",
      "Grep",
      "Edit",
      "Write",
      "Bash"
    ],
    "planner_only_ops": [
      "broad_recursive_scan",
      "unbounded_shell_output",
      "web_search"
    ],
    "bash_allow_prefixes": [
      "git status",
      "git diff",
      "git add",
      "git commit",
      "npm run test",
      "cmake",
      "ctest"
    ],
    "soft_warning_thresholds": {
      "max_output_lines": 240,
      "max_read_kb": 160,
      "warn_avg_tokens_per_tool_call": 3500
    }
  },
  "telemetry": {
    "events_path": ".claude/agent-events.jsonl",
    "weekly_summary_path": ".claude/telemetry-weekly.md"
  }
}
